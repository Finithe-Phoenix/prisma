<?xml version="1.0" encoding="utf-8"?>
<!-- We do not auto-back-up Wine prefixes / translation caches.
     Both are derivable from the original Windows binary the user
     imported, and they can be huge. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
    </device-transfer>
</data-extraction-rules>
