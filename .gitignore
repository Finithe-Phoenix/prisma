# Secrets (NEVER commit)
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# Third-party sources (managed as submodules later)
third_party/*/
!third_party/README.md

# Profiling / telemetry artifacts
*.prof
*.trace
perf.data*

# Coverage runtime artefacts (NOT the tools/coverage/ scripts).
*.gcov
*.gcda
*.gcno

