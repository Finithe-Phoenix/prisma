.gradle/
local.properties
*.apk
*.aab
*.iml
.idea/

# Kotlin
*.class

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
venv/
.venv/
*.egg-info/

